#!/usr/bin/env bash

# .githooks/commit-msg
# Git hook to enforce Conventional Commits format

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Allow merge commits
if [[ "$commit_msg" == Merge* ]]; then
    exit 0
fi

# Regex for Conventional Commits (Title Line)
regex="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-zA-Z0-9_-]+\))?: .+"

# Check Title Line
title_line=$(head -n 1 "$commit_msg_file")
if [[ ! $title_line =~ $regex ]]; then
    echo "❌ ERROR: Title line does not follow Conventional Commits format."
    echo "Format: <type>(<scope>): <description>"
    exit 1
fi

if [ ${#title_line} -gt 72 ]; then
    echo "❌ ERROR: Title line is too long (${#title_line} chars). Keep it under 72."
    exit 1
fi

# Check for blank second line if there is more than one line
line_count=$(wc -l < "$commit_msg_file")
if [ "$line_count" -gt 1 ]; then
    second_line=$(sed -n '2p' "$commit_msg_file")
    if [ -n "$second_line" ]; then
        echo "❌ ERROR: Second line must be blank to separate title from body."
        exit 1
    fi
fi

# Check for body presence (lines after the second)
if [ "$line_count" -lt 3 ]; then
    echo "❌ ERROR: Commit must include a descriptive body after a blank line."
    echo "This ensures deep history is preserved and looks good in GitHub UI."
    exit 1
fi

# Check body length
body_content=$(tail -n +3 "$commit_msg_file" | tr -d '[:space:]')
if [ ${#body_content} -lt 20 ]; then
    echo "❌ ERROR: Commit body is too short. Please provide a more detailed description."
    exit 1
fi

exit 0
